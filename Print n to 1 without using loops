class Solution {
    public void printTillN(int n) {
        // code here
        if(n==0){
            return;
        }
        System.out.print(n+" ");
        printTillN(n-1);
        
    }

    public static void main(String[] args){
        int n = 5;
        Solution obj = new Solution();
        obj.printTillN(n);
  
}
}
